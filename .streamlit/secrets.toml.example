# Streamlit Secrets Example File
# ==================================
# 
# Copy this file to .streamlit/secrets.toml and fill in your values
# DO NOT COMMIT secrets.toml to version control
#
# For local development:
#   1. Copy this file: cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Add your API key
#   3. Run: python main.py or streamlit run frontend/beige_ai_app.py
#
# For Streamlit Cloud:
#   1. Go to https://share.streamlit.io/
#   2. Deploy your app from GitHub
#   3. In App settings > Secrets, add:
#      GEMINI_API_KEY = "your-api-key-here"

GEMINI_API_KEY = "paste-your-google-generativeai-api-key-here"
